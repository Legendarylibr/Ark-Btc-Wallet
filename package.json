{
  "name": "ark-wallet",
  "version": "0.1.0",
  "description": "Ark-only signet wallet UI with barkd or browser WASM backends",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Legendarylibr/Ark-Btc-Wallet.git"
  },
  "bugs": {
    "url": "https://github.com/Legendarylibr/Ark-Btc-Wallet/issues"
  },
  "homepage": "https://github.com/Legendarylibr/Ark-Btc-Wallet#readme",
  "keywords": [
    "ark",
    "bitcoin",
    "wallet",
    "barkd",
    "signet",
    "webauthn"
  ],
  "engines": {
    "node": ">=20"
  },
  "overrides": {
    "postcss": "^8.5.10"
  },
  "scripts": {
    "dev": "next dev --turbopack -H 127.0.0.1",
    "build": "next build",
    "start": "next start -H 127.0.0.1",
    "lint": "eslint src",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:install": "playwright install chromium",
    "lockdown:local": "tsx scripts/lockdown-local.ts",
    "fv:extract": "tsx --tsconfig scripts/tsconfig.json scripts/fv-extract.ts",
    "fv:build": "cd lean && lake build",
    "fv": "npm run fv:extract && npm run fv:build"
  },
  "dependencies": {
    "@noble/ed25519": "^2.3.0",
    "@noble/hashes": "^1.8.0",
    "@scure/base": "^2.2.0",
    "@secondts/bark": "^0.6.3",
    "@simplewebauthn/browser": "^13.3.0",
    "@simplewebauthn/server": "^13.3.2",
    "clsx": "^2.1.1",
    "framer-motion": "^12.42.2",
    "lucide-react": "^0.577.0",
    "next": "^15.5.20",
    "qrcode.react": "^4.2.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "server-only": "^0.0.1",
    "tailwind-merge": "^3.6.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.6",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4.3.3",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^4.1.10",
    "eslint": "^9.39.5",
    "eslint-config-next": "^15.5.20",
    "happy-dom": "^20.10.6",
    "tailwindcss": "^4.3.3",
    "tsx": "^4.23.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.10"
  }
}
