# Copy to .env.local — see docs/configuration.md for full reference

# barkd (default) | sdk (barkd-free browser wallet — docs/sdk-mode.md)
# NEXT_PUBLIC_WALLET_BACKEND=barkd

# Required only when running SDK mode in NODE_ENV=production.
# SDK mode stores wallet material in the browser; read SECURITY.md first.
# ALLOW_SDK_IN_PRODUCTION=true

# barkd REST (loopback only). Ignored when NEXT_PUBLIC_WALLET_BACKEND=sdk.
BARKD_URL=http://127.0.0.1:3535

# Required in production — encrypts .ark-wallet-data/ (min 32 random characters)
SESSION_SECRET=change-me-to-a-long-random-string

# Production defaults to Sec-Fetch-Site: same-origin on mutations; set to relax:
# RELAX_FETCH_SITE=true

# Required in production (barkd mode) unless barkd has no auth API yet.
# Ignored when NEXT_PUBLIC_WALLET_BACKEND=sdk.
# BARKD_AUTH_HEADER=Authorization
# BARKD_AUTH_TOKEN=
# ALLOW_INSECURE_BARKD=true

# Server state directory (sessions, pins, webauthn, nonces)
# WALLET_DATA_DIR=.ark-wallet-data

# Behind a trusted reverse proxy only
# TRUST_PROXY=false

# NEVER true in production (process exits if NODE_ENV=production)
# ALLOW_REMOTE_HOST=false

# When serving the app over HTTPS locally
# ENABLE_HSTS=false

# Aggressive ephemeral TTLs + purge on startup/logout; client cache clear on lock:
# ARK_ZERO_RETENTION=true
# NEXT_PUBLIC_ARK_ZERO_RETENTION=true

# Signet defaults (wallet created via: bark create --signet ...)
ARK_SERVER=https://ark.signet.2nd.dev
ESPLORA_URL=https://esplora.signet.2nd.dev
BARK_NETWORK=signet
