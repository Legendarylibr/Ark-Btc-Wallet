# Copy to .env.local — see docs/configuration.md for full reference

# barkd (default) | sdk (experimental browser wallet — docs/sdk-mode.md)
# NEXT_PUBLIC_WALLET_BACKEND=barkd

# barkd REST (loopback only)
BARKD_URL=http://127.0.0.1:3535

# Required in production — encrypts .ark-wallet-data/ (min 16 characters)
SESSION_SECRET=change-me-to-a-long-random-string

# Optional barkd HTTP auth
# BARKD_AUTH_HEADER=Authorization
# BARKD_AUTH_TOKEN=

# Server state directory (sessions, pins, webauthn, nonces)
# WALLET_DATA_DIR=.ark-wallet-data

# Behind a trusted reverse proxy only
# TRUST_PROXY=false

# NEVER true in production (process exits if NODE_ENV=production)
# ALLOW_REMOTE_HOST=false

# When serving the app over HTTPS locally
# ENABLE_HSTS=false

# Signet defaults (wallet created via: bark create --signet ...)
ARK_SERVER=https://ark.signet.2nd.dev
ESPLORA_URL=https://esplora.signet.2nd.dev
BARK_NETWORK=signet
